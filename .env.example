# ── PostgreSQL superuser (used by Docker init) ───────────────────────────────
POSTGRES_SUPERUSER=admin
POSTGRES_SUPERUSER_PASSWORD=changeme

# ── Airflow metadata DB ──────────────────────────────────────────────────────
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow_password

# ── Airflow config ───────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_SECRET_KEY=your_secret_key_here
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=houcem0508@gmail.com

# ── Sales platform DB (dbt + ingestion) ──────────────────────────────────────
SALES_DB_NAME=sales_platform
SALES_DB_USER=platform_user
SALES_DB_PASSWORD=platform_password

# ── dbt (mirrors SALES_DB_* for CLI use outside Docker) ──────────────────────
DBT_HOST=localhost
DBT_PORT=5432
DBT_DBNAME=sales_platform
DBT_USER=platform_user
DBT_PASSWORD=platform_password

# ── SMTP (for Airflow email alerts) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=houcem0508@gmail.com
SMTP_PASSWORD=your_app_password_here

# ── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=houcem0508@gmail.com
PGADMIN_PASSWORD=admin
